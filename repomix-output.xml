                  <div className="flex flex-wrap gap-x-7 gap-y-3 mt-8 pt-7" style={{ borderTop: '1px solid rgba(240, 237, 230, 0.08)' }}>
                    {project.links.map((link) => (
                      <a
                        key={link.label}
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
